# Server
PORT=3000
NODE_ENV=production

# Admin login (change these before deploying!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here
ADMIN_SESSION_TOKEN=generate-a-long-random-string-here

# Persistent storage on server (recommended for production)
# Put site data + uploaded images outside the app folder so redeploys do not wipe content.
# Example Linux VPS:
# DATA_ROOT=/var/www/profile-data
# This creates: /var/www/profile-data/site-data.json and /var/www/profile-data/img/

# Optional explicit paths:
# DATA_FILE=/var/www/profile-data/site-data.json
# IMG_ROOT=/var/www/profile-data/img
