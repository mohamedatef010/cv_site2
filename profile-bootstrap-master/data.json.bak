  "workflow": {
    "heading": {
      "ar": "خطة العمل",
      "en": "Workflow Plan",
      "ru": "План работы"
    },
    "subtitle": {
      "ar": "خطوات واضحة ومنظمة لتحويل فكرتك إلى مشروع متكامل وناجح.",
      "en": "Clear and organized steps to transform your idea into a successful project.",
      "ru": "Простые и понятные шаги для превращения вашей идеи в успешный проект."
    },
    "steps": [
      {
        "id": "step_1",
        "stepNumber": 1,
        "title": {
          "ar": "تتواصل معي",
          "en": "Contact Me",
          "ru": "Свяжитесь со мной"
        },
        "description": {
          "ar": "البداية بمحادثة نناقش فيها رؤيتك وأهدافك العامة.",
          "en": "Start with a conversation to discuss your general vision and goals.",
          "ru": "Начнем с диалога, чтобы обсудить ваше видение и цели."
        }
      },
      {
        "id": "step_2",
        "stepNumber": 2,
        "title": {
          "ar": "أعرف طلبك وتفاصيله",
          "en": "Understand Details",
          "ru": "Анализ требований"
        },
        "description": {
          "ar": "تحليل متطلباتك بدقة لتحديد الخصائص والميزات التقنية.",
          "en": "Analyze your requirements thoroughly to define technical features.",
          "ru": "Подробный анализ ваших требований для определения функций."
        }
      },
      {
        "id": "step_3",
        "stepNumber": 3,
        "title": {
          "ar": "سأقول لك الوقت اللازم",
          "en": "Estimate Timeframe",
          "ru": "Оценка сроков"
        },
        "description": {
          "ar": "تحديد خطة زمنية واضحة ومراحل لتسليم المهام بدقة.",
          "en": "Define a clear timeline and phases for on-time delivery.",
          "ru": "Определение четких сроков и этапов реализации."
        }
      },
      {
        "id": "step_4",
        "stepNumber": 4,
        "title": {
          "ar": "الاتفاق على أفضل سعر",
          "en": "Best Price Agreement",
          "ru": "Согласование цены"
        },
        "description": {
          "ar": "تقديم تسعير مرن ومناسب لميزانية مشروعك مع أعلى جودة.",
          "en": "Provide flexible pricing customized to your budget with premium quality.",
          "ru": "Гибкое ценообразование под ваш бюджет с высоким качеством."
        }
      },
      {
        "id": "step_5",
        "stepNumber": 5,
        "title": {
          "ar": "تسليم المشروع جاهز كما طلبت",
          "en": "Project Delivery",
          "ru": "Сдача проекта"
        },
        "description": {
          "ar": "إطلاق وتأمين النسخة النهائية من المشروع مع اختبارها بدقة.",
          "en": "Launch and deploy the final tested version of your project.",
          "ru": "Запуск и передача полностью протестированного проекта."
        }
      },
      {
        "id": "step_6",
        "stepNumber": 6,
        "title": {
          "ar": "متابعة مجانية لمدة 6 أشهر",
          "en": "6 Months Free Support",
          "ru": "6 месяцев поддержки"
